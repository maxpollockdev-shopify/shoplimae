{%- assign color_scheme_hash = section.settings.color_scheme.settings.background_gradient | default: section.settings.color_scheme.settings.background | md5 -%}

<div class="section-spacing color-scheme color-scheme--{{ section.settings.color_scheme.id }} color-scheme--bg-{{ color_scheme_hash }} {% if section.settings.separate_section_with_border %}bordered-section{% endif %}">
  <div class="container container--xl">
    <div class="section-stack">
      {%- render 'section-header', subheading: section.settings.subheading, heading: section.settings.title, content: section.settings.content -%}

      {%- assign alphabet = 'a,b,c,d,e,f,g,h,i,j,k,l,m,n,o,p,q,r,s,t,u,v,w,x,y,z' | split: ',' -%}

      <designer-list class="designer-list">
        <div class="designer-list__alphabet">
          <button type="button" class="designer-list__all-button button button--sm is-active" data-show-all>
            All Designers
          </button>

          <ul class="designer-list__letter-list">
            {%- for letter in alphabet -%}
              <button type="button" class="designer-list__letter" data-filter="{{ letter | upcase }}">
                {{- letter | upcase -}}
              </button>
            {%- endfor -%}
          </ul>
        </div>

        <ul class="designer-list__collections" data-collection-list></ul>

        <script type="application/json">
          [
            {% paginate metaobjects.designer.values by 1000 %}
              {%- for designer in metaobjects.designer.values -%}
                {
                  "title": {{ designer.title.value | json }},
                  "url": {{ designer.collection.value.url | json }}
                }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            {% endpaginate %}
          ]
        </script>
      </designer-list>
    </div>
  </div>
</div>

<link rel="stylesheet" href="{{ 'designer-list.css' | asset_url }}">
<script src="{{ 'designer-list.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.designers_list.name",
  "class": "shopify-section--designers-list",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "t:global.section.separate_section_with_border",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "t:global.text.subheading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:global.text.heading",
      "default": "Designers"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:global.text.content"
    }
  ],
  "presets": [
    {
      "name": "t:sections.designers_list.presets.designers_list.name"
    }
  ]
}
{% endschema %}